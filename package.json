{
  "name": "@prjctimg/huetiful",
  "version": "3.0.6",
  "type": "module",
  "main": "./build/huetiful.esm.js",
  "browser": "./build/huetiful.min.js",
  "jsdelivr": "./build/huetiful.min.js",
  "types": "./build/index.d.ts",
  "description": "TypeScript utility library for simple 🧮, fast ⏱️ and accessible ♿ color manipulation.",
  "devDependencies": {
    "@types/bun": "^1.1.9",
    "@types/culori": "^2.1.0",
    "bun": "^1.1.34",
    "prettier": "^3.5.3",
    "tsup": "^8.2.4",
    "typedoc": "^0.28.3",
    "typedoc-plugin-markdown": "^4.6.3",
    "typescript": "^5.0.2"
  },
  "files": [
    "build",
    "CHANGELOG.md",
    "readme.md",
    "contributing.md",
    "license"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/prjctimg/huetiful.git"
  },
  "keywords": [
    "color",
    "stats",
    "culori",
    "palettes",
    "generator",
    "utilities",
    "manipulation",
    "typescript"
  ],
  "author": "Dean Tarisai",
  "email": "prjctimg@outlook.com",
  "homepage": "https://huetiful-js.com",
  "license": "GPL-3.0",
  "bugs": {
    "url": "https://github.com/prjctimg/huetiful/issues"
  },
  "typedocOptions": {
    "entryPoints": [
      "./lib/accessibility",
      "./lib/generators",
      "./lib/palettes",
      "./lib/wrappers",
      "./lib/utils",
      "./lib/collection",
      "./lib/types.d.ts"
    ],
    "excludeTags": [
      "@internal"
    ],
    "outputFileStrategy": "modules",
    "fileExtension": ".md",
    "expandObjects": true,
    "excludeNotDocumented": true,
    "plugin": [
      "typedoc-plugin-markdown",
      "typedoc-plugin-frontmatter"
    ],
    "skipErrorChecking": true,
    "frontmatterCommentTags": [
      "author",
      "description"
    ],
    "entryPointStrategy": "resolve",
    "out": "docs/api",
    "exclude": [
      "./lib/internal.ts"
    ],
    "groupOrder": [
      "Function",
      "Class",
      "Constructor",
      "Property",
      "Method",
      "TypeAlias"
    ],
    "hidePageTitle": true,
    "hidePageHeader": true,
    "hideGroupHeadings": false,
    "cleanOutputDir": false,
    "disableSources": false,
    "readme": "none"
  },
  "directories": {
    "lib": "lib",
    "test": "tests"
  },
  "trustedDependencies": [
    "@biomejs/biome"
  ],
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
